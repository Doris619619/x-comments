[Unit]
Description=x-comments PostgreSQL logical backup
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
User=root
Environment=PROJECT_DIR=/home/ubuntu/opt/x-comments
Environment=BACKUP_DIR=/var/backups/x-comments/postgresql
Environment=RETENTION_DAYS=7
ExecStart=/home/ubuntu/opt/x-comments/scripts/backup_postgres.sh
