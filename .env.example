# 本文件列出 POC 的非敏感配置示例，不得写入真实凭据或登录态。
# Compose 会使用以下账号创建本地 PostgreSQL；云端请替换为托管实例账号。
POSTGRES_DB=x_comments
POSTGRES_USER=xcomments
POSTGRES_PASSWORD=replace-with-a-local-development-password
# Docker Compose 本地示例：运行时统一使用 PostgreSQL，不支持 SQLite 降级。
DATABASE_URL=postgresql+psycopg://xcomments:xcomments@postgres:5432/x_comments
XIANYU_STORAGE_STATE_PATH=storage_state.json
XIANYU_HEADLESS=false
XIANYU_MAX_PAGES=3
XIANYU_MAX_ITEMS=50
# 每个商品详情页最多保留九张公开图库；超出部分不采集，避免异常长列表扩大访问范围。
XIANYU_MAX_IMAGES_PER_ITEM=9
XIANYU_PAGE_DELAY_SECONDS=2.0
# 单个采集任务最多运行两分钟，超时会安全停止，避免队列永久卡住。
XIANYU_COLLECT_TIMEOUT_SECONDS=120
# 商城下单前单商品详情核验必须短于商城侧 HTTP 超时，且每次只访问一次、不重试。
XIANYU_VERIFY_TIMEOUT_SECONDS=12
# 仅供商城服务器调用核验接口；请替换为至少 32 字符的随机令牌，不得提交真实值。
XIANYU_API_TOKEN=
# 全局调度每次只挑选一个到期搜索词，默认每 10 分钟一次。
CATALOG_SCHEDULER_INTERVAL_SECONDS=600
# 独立 scheduler-worker 轮询 API 创建的持久化任务的最长等待时间（秒）。
WORKER_POLL_SECONDS=5
# 连续完整采集未出现多少次后才标记下架；不得小于 2。
CATALOG_MISSING_THRESHOLD=2
# shopping 同步 Catalog 的服务器端 Bearer 令牌；至少 32 字符，不得提交真实值。
CATALOG_SYNC_TOKEN=
# 采购聊天第一阶段默认禁止真实自动发送；只有完成人工验收后才能显式改为 true。
PROCUREMENT_CHAT_ENABLED=false
PROCUREMENT_AUTO_SEND_ENABLED=false
# 模型置信度低于此值时确定性策略阻止发送；不能低于 0.8。
PROCUREMENT_AUTO_SEND_MIN_CONFIDENCE=0.85
# 每个会话自动发送硬上限为 3 轮，配置也不得超过 3。
PROCUREMENT_MAX_AUTO_ROUNDS=3
# 仅供 shopping 服务端调用采购任务 API；必须是独立的至少 32 字符随机令牌。
PROCUREMENT_API_TOKEN=
# 仅接受明确批准的闲鱼 item_id；多个值用英文逗号分隔，留空时采购 API 失败关闭。
PROCUREMENT_SOURCE_ITEM_ALLOWLIST=
# 采购 Worker 的轮询、租约与卖家回复检查间隔；不影响三轮硬上限。
PROCUREMENT_WORKER_POLL_SECONDS=5
PROCUREMENT_TASK_LEASE_SECONDS=90
PROCUREMENT_SELLER_POLL_SECONDS=15
PROCUREMENT_OUTBOX_MAX_ATTEMPTS=8
# 只允许 scheduler-worker 读取。填入只读标定输出的 tracknick SHA-256，禁止填昵称明文。
XIANYU_EXPECTED_ACCOUNT_ID=
# 只允许 scheduler-worker 读取，不得提交真实 DeepSeek 密钥。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=15
# 固定商城内部回调；两项必须同时配置。令牌必须与 PROCUREMENT_API_TOKEN 完全不同。
SHOPPING_CALLBACK_URL=
SHOPPING_PROCUREMENT_TOKEN=
LOG_LEVEL=INFO
